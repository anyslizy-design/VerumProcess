--[[
    Roblox чит-меню с GUI и анимациями для инжектора Xeno.
    Работает в LocalScript, добавляет интерфейс в PlayerGui.
    Кнопки пока что выводят сообщения в консоль — можно заменить на реальные читы.
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Создаём основной ScreenGui (поверх всех)
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "XenoCheatMenu"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

-- === 1. Анимация текста "VerumProcess" ===
local textLabel = Instance.new("TextLabel")
textLabel.Name = "IntroText"
textLabel.Text = "VerumProcess"
textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
textLabel.TextScaled = false
textLabel.TextSize = 20
textLabel.Font = Enum.Font.GothamBold
textLabel.BackgroundTransparency = 1
textLabel.Position = UDim2.new(0, 10, 0, 10)  -- верхний левый угол
textLabel.Size = UDim2.new(0, 200, 0, 40)
textLabel.Parent = screenGui

-- Анимация растяжения на весь экран
local targetSize = UDim2.new(1, 0, 1, 0)
local targetTextSize = 300  -- крупный шрифт на весь экран
local tweenInfo = TweenInfo.new(1.0, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)

local sizeTween = TweenService:Create(textLabel, tweenInfo, {Size = targetSize})
local textTween = TweenService:Create(textLabel, tweenInfo, {TextSize = targetTextSize})

sizeTween:Play()
textTween:Play()

-- По окончании анимации ждём 0.2 сек и резко убираем текст
task.wait(1.2)  -- длительность анимации + чуть-чуть
textLabel.Visible = false
textLabel:Destroy()

-- === 2. Создание основного меню (квадрат с закруглениями) ===
local menuFrame = Instance.new("Frame")
menuFrame.Name = "MainMenu"
menuFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
menuFrame.BackgroundTransparency = 0.15
menuFrame.BorderSizePixel = 0
menuFrame.Size = UDim2.new(0, 0, 0, 0)   -- начинаем с нулевого размера для плавного появления
menuFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
menuFrame.AnchorPoint = Vector2.new(0.5, 0.5)
menuFrame.Parent = screenGui

-- Скругление углов
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 20)
corner.Parent = menuFrame

-- Лёгкая тень (можно добавить слой под меню)
local shadow = Instance.new("Frame")
shadow.Name = "Shadow"
shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
shadow.BackgroundTransparency = 0.6
shadow.BorderSizePixel = 0
shadow.Size = UDim2.new(1, 10, 1, 10)
shadow.Position = UDim2.new(0, -5, 0, -5)
shadow.ZIndex = 0
shadow.Parent = menuFrame

local shadowCorner = Instance.new("UICorner")
shadowCorner.CornerRadius = UDim.new(0, 25)
shadowCorner.Parent = shadow

-- Контейнер для кнопок (вертикальный список)
local buttonContainer = Instance.new("Frame")
buttonContainer.Name = "ButtonContainer"
buttonContainer.BackgroundTransparency = 1
buttonContainer.Size = UDim2.new(0.8, 0, 0.8, 0)
buttonContainer.Position = UDim2.new(0.5, 0, 0.5, 0)
buttonContainer.AnchorPoint = Vector2.new(0.5, 0.5)
buttonContainer.Parent = menuFrame

local uiListLayout = Instance.new("UIListLayout")
uiListLayout.FillDirection = Enum.FillDirection.Vertical
uiListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
uiListLayout.VerticalAlignment = Enum.VerticalAlignment.Center
uiListLayout.SortOrder = Enum.SortOrder.LayoutOrder
uiListLayout.Padding = UDim.new(0, 15)
uiListLayout.Parent = buttonContainer

-- Список кнопок
local buttons = {"JJS", "FPS Flick", "AllPur", "Mem"}
local buttonRefs = {}

for i, btnText in ipairs(buttons) do
    local btn = Instance.new("TextButton")
    btn.Name = btnText:gsub(" ", "")
    btn.Text = btnText
    btn.TextColor3 = Color3.fromRGB(230, 230, 250)
    btn.TextSize = 24
    btn.Font = Enum.Font.GothamSemibold
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    btn.BackgroundTransparency = 0.2
    btn.BorderSizePixel = 0
    btn.Size = UDim2.new(0.8, 0, 0, 45)
    btn.AutoButtonColor = false
    btn.Parent = buttonContainer
    
    -- Скругление для каждой кнопки
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 12)
    btnCorner.Parent = btn
    
    -- Эффект наведения
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 0}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 0.2}):Play()
    end)
    
    -- Действие при клике
    btn.MouseButton1Click:Connect(function()
        print("[Xeno] Нажата кнопка: " .. btnText)
        -- Здесь можно разместить реализацию читов:
        if btnText == "FPS Flick" then
            -- Пример: временно снизить графику для повышения FPS
            local settings = UserSettings():GetService("UserGameSettings")
            settings:Save()
            -- (допишите нужный функционал)
        elseif btnText == "AllPur" then
            -- Очистка всех эффектов или сброс
        elseif btnText == "Mem" then
            -- Показать использование памяти (недоступно в Roblox, но можно симулировать)
        end
    end)
    
    buttonRefs[btnText] = btn
end

-- Плавное появление меню (размер от 0 до половины экрана)
local targetMenuSize = UDim2.new(0.5, 0, 0.6, 0)  -- 50% ширины, 60% высоты
local appearTween = TweenService:Create(menuFrame, TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = targetMenuSize})
appearTween:Play()

-- Дополнительно: анимация появления содержимого (кнопки появляются с задержкой)
for idx, btn in pairs(buttonRefs) do
    btn.BackgroundTransparency = 1
    task.wait(0.05)
    TweenService:Create(btn, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 0.2}):Play()
end

-- Можно добавить возможность закрыть меню по нажатию на клавишу (например, Delete)
local userInputService = game:GetService("UserInputService")
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Delete then
        menuFrame.Visible = not menuFrame.Visible
    end
end)

print("Чит-меню загружено. Нажмите Delete для скрытия/показа.")
